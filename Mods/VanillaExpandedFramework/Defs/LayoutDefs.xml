<?xml version="1.0" encoding="UTF-8"?>
<Defs>

  <!-- Settlement Layout -->

  <KCSG.SettlementLayoutDef>
    <defName>PH_Settlement</defName>
    <settlementSize>80,80</settlementSize>
    <centerBuildings>
      <centerSize>55,55</centerSize>
      <forceClean>true</forceClean>
      <allowedStructures>
        <li>
          <count>1~2</count>
          <tag>PH_Butchery</tag>
        </li>
        <li>
          <count>1~2</count>
          <tag>PH_Genelab</tag>
        </li>
        <li>
          <count>1~2</count>
          <tag>PH_ExtractorRoom</tag>
        </li>
        <li>
          <count>1~1</count>
          <tag>PH_ThroneRoom</tag>
        </li>
        <li>
          <count>1~1</count>
          <tag>PH_AltarRoom</tag>
        </li>
        <li>
          <count>1~1</count>
          <tag>PH_Battery</tag>
        </li>
        <li>
          <count>1~1</count>
          <tag>PH_PodLauncher</tag>
        </li>
        <li>
          <count>2~5</count>
          <tag>PH_Storage</tag>
        </li>
        <li>
          <count>2~4</count>
          <tag>PH_Energy</tag>
        </li>
      </allowedStructures>
    </centerBuildings>
    <peripheralBuildings>
      <allowedStructures>
        <li>
          <count>5~12</count>
          <tag>PH_House</tag>
        </li>
        <li>
          <count>2~4</count>
          <tag>PH_Battery</tag>
        </li>
        <li>
          <count>4~10</count>
          <tag>PH_Defense</tag>
        </li>
      </allowedStructures>
    </peripheralBuildings>
    <stuffableOptions>
      <randomizeFurniture>true</randomizeFurniture>
    </stuffableOptions>
    <propsOptions>
      <scatterProps>true</scatterProps>
      <scatterMinDistance>8</scatterMinDistance>
      <scatterMaxAmount>150</scatterMaxAmount>
      <scatterPropsDefs>
        <li MayRequire="VanillaExpanded.VFEPropsandDecor">VFEPD_BinBag</li>
        <li MayRequire="VanillaExpanded.VFEPropsandDecor">VFEPD_BoxLarge</li>
        <li MayRequire="VanillaExpanded.VFEPropsandDecor">VFEPD_BoxSmall</li>
        <li MayRequire="VanillaExpanded.VFEPropsandDecor">VFEPD_CardboardBoxLarge</li>
        <li MayRequire="VanillaExpanded.VFEPropsandDecor">VFEPD_CardboardBoxSmall</li>
        <li MayRequire="VanillaExpanded.VFEPropsandDecor">VFEPD_BrickPile</li>
        <li MayRequire="VanillaExpanded.VFEPropsandDecor">VFEPD_BarrelGreen</li>
        <li MayRequire="VanillaExpanded.VFEPropsandDecor">VFEPD_PalletCardboard</li>
        <li MayRequire="VanillaExpanded.VFEPropsandDecor">VFEPD_PalletBoxes</li>
        <li MayRequire="VanillaExpanded.VFEPropsandDecor">VFEPD_Pallet</li>
        <li MayRequire="VanillaExpanded.VFEPropsandDecor">VFEPD_PalletBarrelGreen</li>
        <li MayRequire="VanillaExpanded.VFEPropsandDecor">VFEPD_ContainerGreen</li>
        <li MayRequire="VanillaExpanded.VFEPropsandDecor">VFEPD_Pipes</li>
        <li MayRequire="VanillaExpanded.VFEPropsandDecor">VFEPD_Planks</li>
        <li MayRequire="VanillaExpanded.VFEPropsandDecor">VFEPD_ConcreteBags</li>
        <li MayRequire="VanillaExpanded.VFEPropsandDecor">VFEPD_WoodenLogs</li>
        <li MayRequire="VanillaExpanded.VFEPropsandDecor">VFEPD_WoodenLogsLarge</li>
      </scatterPropsDefs>
    </propsOptions>
    <defenseOptions>
      <addEdgeDefense>true</addEdgeDefense>
      <addSandbags>true</addSandbags>
      <addTurrets>true</addTurrets>
      <cellsPerTurret>10</cellsPerTurret>
      <allowedTurretsDefs>
        <li>Turret_MiniTurret</li>
        <li>Turret_Autocannon</li>
        <li>Turret_Sniper</li>
        <li MayRequire="vanillaexpanded.vfesecurity">VFES_SmallRepulsor</li>
        <li MayRequire="vanillaexpanded.vfesecurity">VFES_Turret_MilitaryTurret</li>
        <li MayRequire="vanillaexpanded.vfesecurity">VFES_Turret_ArmoredTurret</li>
        <li MayRequire="vanillaexpanded.vfesecurity">VFES_Turret_ShotgunTurret</li>
        <li MayRequire="vanillaexpanded.vfesecurity">VFES_Turret_AutocannonDouble</li>
        <li MayRequire="vanillaexpanded.vfesecurity">VFES_Turret_Minigun</li>
        <li MayRequire="vanillaexpanded.vfesecurity">VFES_Turret_ChargeTurret</li>
        <li MayRequire="vanillaexpanded.vfesecurity">VFES_Turret_ChargeRailgun</li>
      </allowedTurretsDefs>
      <addMortars>true</addMortars>
      <pawnGroupMultiplier>1.3</pawnGroupMultiplier>
    </defenseOptions>
    <stockpileOptions>
      <fillStorageBuildings>true</fillStorageBuildings>
      <fillWithDefs>
        <li>Gold</li>
        <li>Silver</li>
        <li>AIPersonaCore</li>
        <li>MechSerumHealer</li>
        <li>MechSerumResurrector</li>
        <li>ComponentIndustrial</li>
        <li>ComponentSpacer</li>
        <li>MedicineUltratech</li>
        <li>Plasteel</li>
        <li>Hyperweave</li>
        <li MayRequire="Ludeon.RimWorld.Biotech">SubcoreRegular</li>
        <li MayRequire="Ludeon.RimWorld.Biotech">SubcoreHigh</li>
        <li MayRequire="Ludeon.RimWorld.Biotech">NanostructuringChip</li>
        <li MayRequire="Ludeon.RimWorld.Royalty">BroadshieldCore</li>
        <li MayRequire="Ludeon.RimWorld.Biotech">HemogenPack</li>
        <li MayRequire="Ludeon.RimWorld.Biotech">Genepack</li>
        <li MayRequire="Ludeon.RimWorld.Anomaly">VoidsightSerum</li>
        <li MayRequire="Ludeon.RimWorld.Anomaly">MetalbloodSerum</li>
        <li MayRequire="Ludeon.RimWorld.Anomaly">JuggernautSerum</li>
        <li MayRequire="Ludeon.RimWorld.Anomaly">Bioferrite</li>
        <li>Neutroamine</li>
        <li>Shell_AntigrainWarhead</li>
        <li MayRequire="Ludeon.RimWorld.Biotech">Shell_Toxic</li>
        <li>Chemfuel</li>
        <li>MealSurvivalPack</li>
        <li>Apparel_PowerArmor</li>
        <li>Apparel_PowerArmorHelmet</li>
        <li>Apparel_ArmorRecon</li>
        <li>Apparel_ArmorHelmetRecon</li>
        <li>Apparel_AdvancedHelmet</li>
        <li>Apparel_FlakVest</li>
        <li>Apparel_FlakJacket</li>
        <li>Apparel_FlakPants</li>
        <li>Apparel_ShieldBelt</li>
        <li>Apparel_SmokepopBelt</li>
        <li>Apparel_PsychicShockLance</li>
        <li>Apparel_PsychicInsanityLance</li>
        <li MayRequire="Ludeon.RimWorld.Royalty">Apparel_ArmorMarinePrestige</li>
        <li MayRequire="Ludeon.RimWorld.Royalty">Apparel_ArmorMarineHelmetPrestige</li>
        <li MayRequire="Ludeon.RimWorld.Royalty">Apparel_PackJump</li>
        <li MayRequire="Ludeon.RimWorld.Royalty">Apparel_PackBroadshield</li>
        <li MayRequire="Ludeon.RimWorld.Royalty">Apparel_Gunlink</li>
        <li MayRequire="Ludeon.RimWorld.Royalty">Apparel_ArmorMarineGrenadier</li>
        <li MayRequire="Ludeon.RimWorld.Biotech">Apparel_HeavyShield</li>
        <li MayRequire="Ludeon.RimWorld.Biotech">Apparel_PackTox</li>
        <li MayRequire="Ludeon.RimWorld.Anomaly">Apparel_ShardPsychicShockLance</li>
        <li MayRequire="Ludeon.RimWorld.Anomaly">Apparel_ShardPsychicInsanityLance</li>
        <li MayRequire="Ludeon.RimWorld.Anomaly">Apparel_BiomutationLance</li>
        <li MayRequire="Ludeon.RimWorld.Anomaly">Apparel_DeadlifePack</li>
        <li MayRequire="Ludeon.RimWorld.Anomaly">Apparel_DisruptorFlarePack</li>
        <li MayRequire="Ludeon.RimWorld.Anomaly">Apparel_PackTurret</li>
        <li MayRequire="Ludeon.RimWorld.Odyssey">Apparel_Vacsuit</li>
        <li MayRequire="Ludeon.RimWorld.Odyssey">Apparel_VacsuitHelmet</li>
        <li MayRequire="Ludeon.RimWorld.Odyssey">Apparel_PackHunter</li>
        <li MayRequire="Ludeon.RimWorld.Royalty">MeleeWeapon_MonoSword</li>
        <li MayRequire="Ludeon.RimWorld.Royalty">MeleeWeapon_Zeushammer</li>
        <li MayRequire="Ludeon.RimWorld.Royalty">MeleeWeapon_PlasmaSword</li>
        <li MayRequire="Ludeon.RimWorld.Royalty">MeleeWeapon_MonoSwordBladelink</li>
        <li MayRequire="Ludeon.RimWorld.Royalty">MeleeWeapon_ZeusHammerBladelink</li>
        <li MayRequire="Ludeon.RimWorld.Royalty">MeleeWeapon_PlasmaSwordBladelink</li>
        <li>Gun_ChargeRifle</li>
        <li>Gun_ChargeLance</li>
        <li MayRequire="Ludeon.RimWorld.Odyssey">Gun_BeamRepeater</li>
        <li>Gun_AssaultRifle</li>
        <li>Gun_SniperRifle</li>
        <li>Gun_Minigun</li>
        <li>Gun_ChainShotgun</li>
        <li>Gun_LMG</li>
        <li>Gun_IncendiaryLauncher</li>
        <li>Gun_EmpLauncher</li>
        <li>Weapon_GrenadeEMP</li>
        <li>Weapon_GrenadeFrag</li>
        <li>Gun_DoomsdayRocket</li>
        <li>Gun_TripleRocket</li>
        <li MayRequire="Ludeon.RimWorld.Biotech">Gun_ToxbombLauncher</li>
        <li MayRequire="Ludeon.RimWorld.Biotech">Weapon_GrenadeTox</li>
        <li>OrbitalTargeterBombardment</li>
        <li>OrbitalTargeterPowerBeam</li>
        <li>TornadoGenerator</li>
      </fillWithDefs>
      <fillChance>0.5</fillChance>
    </stockpileOptions>
  </KCSG.SettlementLayoutDef>

</Defs>