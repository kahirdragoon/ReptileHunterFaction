<?xml version="1.0" encoding="UTF-8"?>
<Defs>
    <SitePartDef>
        <defName>PH_KidnappedPawnPrison</defName>
        <label>pawn kidnapped by the hunters</label>
        <description>A kidnapped pawn from your faction is being held in an extraction chamber. Rescue them or they will die.</description>
        <workerClass>PawnHunters.SitePartWorker_PHPrison</workerClass>
        <siteTexture>World/WorldObjects/Sites/GenericSite</siteTexture>
        <expandingIconTexture>World/WorldObjects/Expanding/Sites/Prisoner</expandingIconTexture>
        <forceExitAndRemoveMapCountdownDurationDays>6</forceExitAndRemoveMapCountdownDurationDays>
        <requiresFaction>true</requiresFaction>
        <handlesWorldObjectTimeoutInspectString>true</handlesWorldObjectTimeoutInspectString>
        <gravShipsCanLandOn>true</gravShipsCanLandOn>
        <tags>
            <li>PH_KidnappedPawnPrison</li>
        </tags>
    </SitePartDef>

    <GenStepDef>
        <defName>PH_KidnappedPawnPrison</defName>
        <linkWithSite>PH_KidnappedPawnPrison</linkWithSite>
        <order>1600</order>
        <genStep Class="PawnHunters.GenStep_PHPrison">
            <count>1</count>
            <nearMapCenter>true</nearMapCenter>
        </genStep>
    </GenStepDef>

</Defs>
