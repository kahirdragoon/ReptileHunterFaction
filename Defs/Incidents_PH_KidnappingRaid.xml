<?xml version="1.0" encoding="utf-8"?>
<Defs>

    <!-- ===== Job ===== -->
    <JobDef>
        <defName>PH_KidnapAndFlee</defName>
        <driverClass>PawnHunters.JobDriver_PH_KidnapAndFlee</driverClass>
        <label>kidnap and flee</label>
        <reportString>kidnapping TargetA and escaping.</reportString>
        <allowOpportunisticPrefix>false</allowOpportunisticPrefix>
        <collideWithPawns>true</collideWithPawns>
    </JobDef>

    <!-- ===== Duty for the designated kidnapper ===== -->
    <!--
        The duty think tree has a single job giver.  It fires only for the pawn
        that LordJob_PH_KidnappingRaid has tagged as the kidnapper, so every
        other raider keeps their normal AssaultColony duty unaffected.
    -->
    <DutyDef>
        <defName>PH_KidnaperDuty</defName>
        <label>kidnapper</label>
        <thinkNode Class="ThinkNode_Priority">
            <subNodes>
                <li Class="PawnHunters.JobGiver_PH_KidnapDowned" />
            </subNodes>
        </thinkNode>
    </DutyDef>

    <!-- ===== Skull extractor duty ===== -->
    <DutyDef>
        <defName>PH_SkullExtractorDuty</defName>
        <label>skull extractor</label>
        <thinkNode Class="ThinkNode_Priority">
            <subNodes>
                <li Class="PawnHunters.JobGiver_PH_ExtractSkull" />
            </subNodes>
        </thinkNode>
    </DutyDef>

    <!-- ===== Raid strategy ===== -->
    <!--
        Walks in from the map edge just like a standard immediate-attack raid.
        The custom worker swaps the LordJob for LordJob_PH_KidnappingRaid.
    -->
    <RaidStrategyDef>
        <defName>PH_KidnappingRaidStrategy</defName>
        <workerClass>PawnHunters.RaidStrategyWorker_PH_KidnappingRaid</workerClass>
        <label>kidnapping assault</label>
        <selectionWeightPerPointsCurve>
            <points>
                <li>(0, 1)</li>
            </points>
        </selectionWeightPerPointsCurve>
        <letterLabelEnemy>Kidnapping raid</letterLabelEnemy>
        <arrivalTextEnemy>The hunters are here to kidnap your pawns. They will fight and try to drag downed colonists back to their base.</arrivalTextEnemy>
        <pawnsCanBringFood>false</pawnsCanBringFood>
        <arriveModes>
            <li>EdgeWalkIn</li>
            <li>EdgeWalkInGroups</li>
            <li>EdgeDrop</li>
            <li>EdgeDropGroups</li>
            <li>CenterDrop</li>
            <li>RandomDrop</li>
        </arriveModes>
    </RaidStrategyDef>

    <!-- ===== Incident ===== -->
    <!--
        Sits alongside the standard raid incidents in the ThreatBig pool.
        IncidentWorker_PH_KidnappingRaid enforces:
          - Faction is always PH_PawnHunters.
          - Player must have between 3 and 6 free colonists.
          - Raider count is always (free colonists - 1); storyteller points are ignored.
    -->
    <IncidentDef>
        <defName>PH_KidnappingRaid</defName>
        <workerClass>PawnHunters.IncidentWorker_PH_KidnappingRaid</workerClass>
        <label>pawn hunter kidnapping raid</label>
        <category>ThreatBig</category>
        <targetTags>
            <li>Map_PlayerHome</li>
        </targetTags>
        <baseChance>0.9</baseChance>
        <minThreatPoints>50</minThreatPoints>
        <letterLabel>Reptile hunter kidnapping raid</letterLabel>
        <letterText>A pack of pawn hunters approaches! They will fight until they can snatch one of your people and drag them back to their lairs — or until half their number is cut down.</letterText>
        <letterDef>ThreatBig</letterDef>
    </IncidentDef>

</Defs>
